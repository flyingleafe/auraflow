# Copy to .env and fill in. Never commit .env. `direnv`/`python-dotenv` loads it.
#
# These credentials are only needed for the optional `data` extra (dataset
# output management via dload, PyPI `dload-ml`). The base library and all
# generation scripts run without them; only committing/reading dload datasets
# (scripts/jasa_generate.py full runs, scripts/cona_vs_cfd.py --commit-dload)
# touches the remote.

# Cloudflare R2 — dload reads these as S3 credentials.
#   Create an R2 API token (Object Read & Write, scoped to the bucket) at
#   https://dash.cloudflare.com/<acct>/r2/api-tokens
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Your R2 account id (dload builds the endpoint URL from it, or use the
# endpoint_url already set in ./dload.toml).
R2_ACCOUNT_ID=
# R2 ignores standard AWS region names; this must be literally "auto".
AWS_DEFAULT_REGION=auto
